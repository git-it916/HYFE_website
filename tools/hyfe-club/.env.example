# Supabase — Activities CMS 백엔드 (선택)
# 아래 두 값이 없으면 사이트는 자동으로 localStorage 폴백 모드로 동작합니다.
# 값은 Supabase 대시보드 → Project Settings → API 에서 복사.
# anon key는 공개돼도 안전합니다(RLS로 보호). 진짜 비밀키(service_role)는 절대 넣지 마세요.
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# 로컬 모드(Supabase 미설정 시) 관리자 로그인 ID/PW. 미설정 시 기본값 admin / hyfe2024.
# Supabase 모드에서는 ID = Supabase 계정 이메일이 됩니다.
VITE_ADMIN_ID=admin
VITE_ADMIN_PW=hyfe2024
VITE_ADMIN_NAME=신승훈
